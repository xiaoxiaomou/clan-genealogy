# ============================================================
#  族谱管理平台 - 环境变量示例
#  复制本文件为 .env 并按需修改；.env 不会被提交到 Git
#  Copy this file to .env and adjust the values as needed.
# ============================================================

# ---- 运行环境 / Runtime ----
# development | production | testing
FLASK_CONFIG=development
# 监听地址（本地默认 127.0.0.1；局域网/容器内可设 0.0.0.0）
HOST=127.0.0.1
PORT=5000

# ---- 安全密钥（生产环境必须修改，否则拒绝启动）----
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex
JWT_SECRET_KEY=change-me-to-another-random-64-char-hex

# ---- 数据库 / Database ----
# 开发环境不填则默认使用 SQLite (zupu.db)
# SQLite  示例: sqlite:///zupu.db
# MySQL   示例: mysql+pymysql://user:password@localhost:3306/zupu?charset=utf8mb4
# Postgres示例: postgresql+psycopg://user:password@localhost:5432/zupu
DATABASE_URI=

# ---- CORS 跨域白名单（逗号分隔）----
# 前端地址；未配置时严格模式将拦截所有跨域请求
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ---- 业务配置 / Business ----
# 活人隐私保护：出生距今不超过 N 年的成员视为"活人"，
# 对非 owner/editor 隐藏敏感字段
LIVING_PROTECTION_YEARS=100
